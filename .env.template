# =============================================================================
# PFE v2 Mobile — Environment Variables Template
# Copy this file to `.env` (or `.env.local` / `.env.development`) and fill in real values.
# In Expo SDK 49+, variables starting with EXPO_PUBLIC_ are exposed to the client bundle.
# =============================================================================

# --- Supabase Configuration ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase Admin (server-side scripts only) ---
# Used by: `npm run seed:test-users`
# NEVER prefix this with EXPO_PUBLIC_. Keep it secret and do not commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides for the seed script (defaults are fine)
SEED_OPERATOR_EMAIL=
SEED_OPERATOR_PASSWORD=
SEED_DASHBOARD_EMAIL=
SEED_DASHBOARD_PASSWORD=
