{
  "expo": {
    "name": "Médis Supervision",
    "slug": "medis-supervision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.jpeg",
    "scheme": "medis-supervision",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ffffff",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tn.medis.supervision"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo.jpeg",
        "monochromeImage": "./assets/images/logo.jpeg"
      },
      "package": "tn.medis.supervision"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "android": {
            "image": "./assets/images/logo.jpeg",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.jpeg",
          "color": "#3b5bff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
