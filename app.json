{
  "expo": {
    "name": "Médis Supervision",
    "slug": "medis-supervision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medis-supervision",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#090d16",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tn.medis.supervision"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#090d16",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "tn.medis.supervision"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#090d16",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3b5bff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
